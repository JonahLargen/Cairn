# Normalize line endings: let Git decide on checkin, check out native.
* text=auto

# Explicitly text
*.cs        text diff=csharp
*.csproj    text
*.props     text
*.targets   text
*.slnx      text
*.json      text
*.yml       text
*.yaml      text
*.md        text
*.editorconfig text

# Binary
*.png       binary
*.jpg       binary
*.gif       binary
*.ico       binary
*.snk       binary
*.dll       binary
